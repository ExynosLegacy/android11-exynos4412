#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/ui.sh"

COMMAND="${1:-help}"

case "$COMMAND" in
    status)
        source "$SCRIPT_DIR/commands/status.sh"
        cmd_status
        ;;

    doctor)
        source "$SCRIPT_DIR/commands/doctor.sh"
        cmd_doctor
        ;;

    bootstrap)
        source "$SCRIPT_DIR/commands/bootstrap_build_host.sh"
        cmd_bootstrap
        ;;

    manifest)
        source "$SCRIPT_DIR/commands/manifest.sh"
        cmd_manifest
        ;;

    env)
        source "$SCRIPT_DIR/commands/env.sh"
        cmd_env
        ;;

    help)
        echo "ExynosLegacy Project Manager"
        echo
        echo "Available commands:"
        echo "  status"
        echo "  doctor"
        echo "  bootstrap"
        echo "  manifest"
        echo "  env"
        ;;

    *)
        echo "Unknown command: $COMMAND"
        echo
        echo "Run:"
        echo "  project help"
        exit 1
        ;;
esac
